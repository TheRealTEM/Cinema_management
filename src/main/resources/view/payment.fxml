<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0"
            prefWidth="1280.0"
            styleClass="booking-page"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dp.controller.PaymentController">

    <children>

        <VBox spacing="30"
              alignment="TOP_CENTER"
              AnchorPane.topAnchor="100"
              AnchorPane.leftAnchor="430">

            <Label text="Payment"
                   style="-fx-font-size: 34px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>

            <VBox spacing="18"
                  maxWidth="420"
                  prefWidth="420"
                  styleClass="booking-sidebar">

                <padding>
                    <Insets top="30"
                            right="30"
                            bottom="30"
                            left="30"/>
                </padding>

                <Label text="Movie"
                       style="-fx-text-fill: #9b9b9b;
                              -fx-font-size: 14px;"/>

                <Label fx:id="movieTitleLabel"
                       text="Movie Name"
                       style="-fx-text-fill: white;
                              -fx-font-size: 28px;
                              -fx-font-weight: bold;"/>

                <Separator style="-fx-background-color: #2d1a40;"/>

                <Label text="Selected Seats"
                       style="-fx-text-fill: #9b9b9b;
                              -fx-font-size: 14px;"/>

                <Label fx:id="seatsLabel"
                       text="Seats: A1, A2"
                       style="-fx-text-fill: white;
                              -fx-font-size: 18px;"/>

                <Separator style="-fx-background-color: #2d1a40;"/>

                <Label text="Total Price"
                       style="-fx-text-fill: #9b9b9b;
                              -fx-font-size: 14px;"/>

                <Label fx:id="totalLabel"
                       text="\$30"
                       style="-fx-text-fill: #c43cff;
                              -fx-font-size: 30px;
                              -fx-font-weight: bold;"/>

                <ComboBox fx:id="paymentMethodComboBox"
                          promptText="Select Payment Method"
                          prefWidth="360"
                          style="-fx-background-color: #1f1329;
                                 -fx-border-color: #9126ff;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-font-size: 15px;"/>

                <Button text="Confirm Payment"
                        fx:id="confirmPaymentButton"
                        onAction="#handleConfirmPayment"
                        prefWidth="360"
                        prefHeight="50"
                        styleClass="booking-pay-button"/>

            </VBox>

        </VBox>

    </children>

</AnchorPane>