<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dp.controller.DashboardController">
   <children>
<BorderPane>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0" spacing="25.0" styleClass="navbar" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="20.0" />
         </padding>
         <children>
            <Label styleClass="booking-nav-active" text="Movies" />
            <Label text="My Bookings"
                   onMouseClicked="#handleMyBookings"
                   style="-fx-cursor: hand;"/>
         </children></HBox>
   </top>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="root-pane" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_RIGHT" prefHeight="10.0" prefWidth="200.0" spacing="25.0">
               <children>
                  <Label fx:id="nowPlayingLabel" styleClass="active-category" text="Now Playing" onMouseClicked="#handleNowPlayingClick"/>
                  <Label fx:id="comingSoonLabel" styleClass="inactive-category" text="Coming Soon" onMouseClicked="#handleComingSoonClick"/>
                  <ComboBox fx:id="genreComboBox"
                            promptText="Select Genre"
                            onAction="#handleGenreFilter"
                            prefWidth="180"/>
               </children>
               <padding>
                  <Insets bottom="10.0" right="25.0" />
               </padding>
            </HBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true" prefHeight="420.0" prefWidth="200.0" styleClass="movies-scroll">
               <content>
                  <HBox fx:id="moviesContainer" prefHeight="100.0" prefWidth="200.0" spacing="25.0">
                     <padding>
                        <Insets top="30.0" />
                     </padding>
                  </HBox>
               </content>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </ScrollPane>
         </children>
         <padding>
            <Insets top="20.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
      <StackPane fx:id="modalOverlay" visible="false" styleClass="modal-overlay" onMouseClicked="#handleCloseModal">
         <children>
            <VBox fx:id="movieModal" styleClass="movie-modal" maxHeight="500" maxWidth="700" onMouseClicked="#consumeClick">
               <children>
                  <HBox spacing="20">
                     <children>
                        <ImageView fx:id="modalPoster" fitHeight="300" fitWidth="200" preserveRatio="false" />
                        <VBox spacing="10">
                           <children>
                              <HBox alignment="CENTER_RIGHT">
                                 <Button text="✕" styleClass="modal-close-button" onAction="#handleCloseModal"/>
                              </HBox>
                              <Label fx:id="modalTitle" styleClass="modal-title" text="Movie Title"/>
                              <Label fx:id="modalGenre" styleClass="modal-genre" text="Genre"/>
                              <Label fx:id="modalDuration" styleClass="modal-duration" text="120 min"/>
                              <Label fx:id="modalRating" styleClass="modal-rating" text="PG-13"/>
                              <Label fx:id="modalReleaseDate" styleClass="modal-release" text="2026-05-15"/>
                              <Label fx:id="modalDescription" styleClass="modal-description" text="Description here..." wrapText="true" prefWidth="400"/>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                     <Label fx:id="modalActionTitle" styleClass="modal-action-title" text="Available Showtimes"/>
                     <HBox fx:id="modalShowtimesContainer" spacing="10" />
                     <Button fx:id="modalActionButton" styleClass="book-button" text="Action" visible="false" managed="false"/>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</StackPane>
