<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="900.0" prefWidth="1440.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dp.controller.AdminDashboardController">

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" styleClass="admin-header">
            <padding>
                <Insets left="20.0" right="20.0" top="15.0" bottom="15.0"/>
            </padding>
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="StarFlix Admin"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label style="-fx-text-fill: #b8b3c7; -fx-font-size: 12px;" fx:id="currentUserLabel" text="Admin"/>
            </children>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <HBox spacing="0">
            <!-- LEFT SIDEBAR NAVIGATION -->
            <VBox prefWidth="250.0" styleClass="admin-sidebar">
                <padding>
                    <Insets top="20.0"/>
                </padding>
                <children>
                    <Label fx:id="overviewNav" styleClass="admin-nav-item,admin-nav-item-active" text="📊 Overview"/>
                    <Label fx:id="moviesNav" styleClass="admin-nav-item" text="🎬 Movie Management"/>
                    <Label fx:id="bookingsNav" styleClass="admin-nav-item" text="🎫 Bookings Management"/>
                    <Label fx:id="paymentsNav" styleClass="admin-nav-item" text="💳 Payments Management"/>
                </children>
            </VBox>

            <!-- CONTENT AREA -->
            <VBox HBox.hgrow="ALWAYS" spacing="20.0" styleClass="root-pane">
                <padding>
                    <Insets left="30.0" right="30.0" top="30.0" bottom="30.0"/>
                </padding>

                <!-- OVERVIEW SECTION -->
                <VBox fx:id="overviewSection" spacing="20.0">
                    <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Dashboard Overview"/>

                    <!-- STATS CARDS -->
                    <HBox spacing="20.0">
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Total Bookings"/>
                            <Label styleClass="admin-card-value" fx:id="totalBookingsLabel" text="0"/>
                        </VBox>
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Total Revenue"/>
                            <Label styleClass="admin-card-value" fx:id="totalRevenueLabel" text="\$0"/>
                        </VBox>
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Active Movies"/>
                            <Label styleClass="admin-card-value" fx:id="activeMoviesLabel" text="0"/>
                        </VBox>
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Pending Bookings"/>
                            <Label styleClass="admin-card-value" fx:id="pendingBookingsLabel" text="0"/>
                        </VBox>
                    </HBox>

                    <!-- RECENT BOOKINGS TABLE -->
                    <VBox spacing="10.0">
                        <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Recent Bookings (Last 10)"/>
                        <TableView fx:id="recentBookingsTable" prefHeight="300.0" styleClass="admin-table">
                            <columns>
                                <TableColumn prefWidth="100.0" text="Booking ID"/>
                                <TableColumn prefWidth="150.0" text="User"/>
                                <TableColumn prefWidth="150.0" text="Movie"/>
                                <TableColumn prefWidth="100.0" text="Amount"/>
                                <TableColumn prefWidth="100.0" text="Status"/>
                                <TableColumn prefWidth="150.0" text="Date"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>

                <!-- MOVIE MANAGEMENT SECTION -->
                <VBox fx:id="moviesSection" spacing="20.0" visible="false">
                    <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Movie Management"/>

                    <HBox spacing="10.0">
                        <Button styleClass="admin-button" onAction="#handleAddMovie" text="+ Add Movie"/>
                        <Button styleClass="admin-button-secondary" onAction="#handleEditMovie" text="Edit Selected"/>
                        <Button styleClass="admin-button-secondary" onAction="#handleDeleteMovie" text="Delete Selected"/>
                    </HBox>

                    <TableView fx:id="moviesTable" prefHeight="400.0" styleClass="admin-table">
                        <columns>
                            <TableColumn prefWidth="150.0" text="Title"/>
                            <TableColumn prefWidth="100.0" text="Genre"/>
                            <TableColumn prefWidth="80.0" text="Duration (min)"/>
                            <TableColumn prefWidth="100.0" text="Status"/>
                            <TableColumn prefWidth="120.0" text="Release Date"/>
                            <TableColumn prefWidth="100.0" text="Actions"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- BOOKINGS MANAGEMENT SECTION -->
                <VBox fx:id="bookingsSection" spacing="20.0" visible="false">
                    <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Bookings Management"/>

                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #b8b3c7; -fx-font-size: 14px;" text="Filter by Status:"/>
                        <ComboBox fx:id="bookingStatusFilter" prefWidth="150.0" promptText="All Statuses" style="-fx-background-color: #241833; -fx-text-fill: white; -fx-border-color: #9126ff; -fx-border-radius: 4;"/>
                        <Button styleClass="admin-button" onAction="#handleConfirmBooking" text="Confirm Selected"/>
                        <Button styleClass="admin-button-secondary" onAction="#handleCancelBooking" text="Cancel Selected"/>
                    </HBox>

                    <TableView fx:id="bookingsTable" prefHeight="400.0" styleClass="admin-table">
                        <columns>
                            <TableColumn prefWidth="80.0" text="Booking ID"/>
                            <TableColumn prefWidth="120.0" text="User"/>
                            <TableColumn prefWidth="150.0" text="Movie"/>
                            <TableColumn prefWidth="100.0" text="Showtime"/>
                            <TableColumn prefWidth="100.0" text="Amount"/>
                            <TableColumn prefWidth="100.0" text="Status"/>
                            <TableColumn prefWidth="120.0" text="Actions"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- PAYMENTS MANAGEMENT SECTION -->
                <VBox fx:id="paymentsSection" spacing="20.0" visible="false">
                    <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Payments Management"/>

                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #b8b3c7; -fx-font-size: 14px;" text="Filter by Status:"/>
                        <ComboBox fx:id="paymentStatusFilter" prefWidth="150.0" promptText="All Statuses" style="-fx-background-color: #241833; -fx-text-fill: white; -fx-border-color: #9126ff; -fx-border-radius: 4;"/>
                        <Label style="-fx-text-fill: #b8b3c7; -fx-font-size: 14px; -fx-padding: 0 0 0 30px;" text="Filter by Method:"/>
                        <ComboBox fx:id="paymentMethodFilter" prefWidth="150.0" promptText="All Methods" style="-fx-background-color: #241833; -fx-text-fill: white; -fx-border-color: #9126ff; -fx-border-radius: 4;"/>
                    </HBox>

                    <!-- SUMMARY STATS -->
                    <HBox spacing="20.0">
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Card Payments"/>
                            <Label styleClass="admin-card-value" fx:id="cardPaymentsLabel" text="\$0"/>
                        </VBox>
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Cash Payments"/>
                            <Label styleClass="admin-card-value" fx:id="cashPaymentsLabel" text="\$0"/>
                        </VBox>
                        <VBox styleClass="admin-card" HBox.hgrow="ALWAYS">
                            <spacing>5.0</spacing>
                            <Label styleClass="admin-card-title" text="Wallet Payments"/>
                            <Label styleClass="admin-card-value" fx:id="walletPaymentsLabel" text="\$0"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="paymentsTable" prefHeight="350.0" styleClass="admin-table">
                        <columns>
                            <TableColumn prefWidth="80.0" text="Payment ID"/>
                            <TableColumn prefWidth="80.0" text="Booking ID"/>
                            <TableColumn prefWidth="100.0" text="Amount"/>
                            <TableColumn prefWidth="120.0" text="Method"/>
                            <TableColumn prefWidth="100.0" text="Status"/>
                            <TableColumn prefWidth="120.0" text="Date"/>
                            <TableColumn prefWidth="120.0" text="Actions"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>

